{
  "name": "langgraph-checkpoint-sqlite-native",
  "type": "module",
  "version": "0.0.1",
  "description": "LangGraph Checkpoint saver using native SQLite for Node.js and Bun.",
  "keywords": [
    "langgraph",
    "checkpoint",
    "sqlite",
    "bun",
    "nodejs",
    "langchain"
  ],
  "author": "Wyatex <wyatex@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/Herta-ai/langgraph-checkpoint-sqlite-native#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Herta-ai/langgraph-checkpoint-sqlite-native.git"
  },
  "bugs": {
    "url": "https://github.com/Herta-ai/langgraph-checkpoint-sqlite-native/issues"
  },
  "exports": {
    "./bun": "./dist/bun.mjs",
    "./nodejs": "./dist/nodejs.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test:nodejs": "vitest run ./tests/nodejs.test.ts",
    "test:bun": "bun run --bun vitest run ./tests/bun.test.ts",
    "test:deno": "deno task test:nodejs",
    "test": "npm run test:nodejs && npm run test:bun && npm run test:deno",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph-checkpoint": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/deno": "^2.7.0",
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {}
}
